POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me-before-start
POSTGRES_DB=airflow
STOCK_DB_USER=stock_app
STOCK_DB_PASSWORD=change-me-before-start
AIRFLOW_ADMIN_PASSWORD=change-me-before-start
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_PORT=8080
VIEWER_PORT=3000

# Use the same immutable commit SHA for all three images.
AIRFLOW_IMAGE=ghcr.io/nowonbun/stockersearcher_v2-airflow:sha-<commit-sha>
VIEWER_IMAGE=ghcr.io/nowonbun/stockersearcher_v2-viewer:sha-<commit-sha>
POSTGRES_IMAGE=ghcr.io/nowonbun/stockersearcher_v2-postgres:sha-<commit-sha>

# This server-local directory contains model_*.pt files and is not Git content.
MODEL_DIR=/srv/stockersearcher/models

# Docker Desktop on Windows can use the default AIRFLOW_UID value.
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_PORT=8080
POSTGRES_HOST_PORT=5432
POSTGRES_USER=airflow
POSTGRES_DB=airflow
POSTGRES_PASSWORD=change-me-before-start
STOCK_DB_USER=stock_app
STOCK_DB_PASSWORD=change-me-before-start

# Change these before exposing Airflow outside a local development machine.
_AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_ADMIN_PASSWORD=change-me-before-start

# Nuxt viewer. VIEWER_API_PROXY_TARGET must be reachable from the viewer container.
VIEWER_PORT=3000

# Server deployment only: immutable GHCR image tags published by GitHub Actions.
# AIRFLOW_IMAGE=ghcr.io/nowonbun/stockersearcher_v2-airflow:sha-<commit-sha>
# VIEWER_IMAGE=ghcr.io/nowonbun/stockersearcher_v2-viewer:sha-<commit-sha>
